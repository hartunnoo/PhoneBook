@inherits LayoutComponentBase
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<header class="top-bar">
    <div class="top-bar-content">
        <span class="top-bar-title" style="text-transform:uppercase;letter-spacing:.04em">Direktori <span style="color:var(--hmo-gold)">AI</span></span>
        <div class="top-bar-actions">
            @if (isLoggedIn)
            {
                <div class="avatar-menu">
                    <button class="avatar sm ac@avColor" @onclick="ToggleMenu" style="width:40px;height:40px;font-size:.9rem;border:2px solid rgba(201,164,59,.3)">@initial</button>
                    @if (showMenu)
                    {
                        <div class="menu-scrim" @onclick="CloseMenu"></div>
                        <div class="menu-sheet">
                            <div class="menu-sheet-handle"></div>
                            <div style="padding:12px 24px 16px;display:flex;align-items:center;gap:14px">
                                <div class="avatar lg ac@avColor" style="width:52px;height:52px">@initial</div>
                                <div>
                                    <div style="font-weight:600;font-size:1rem">@username</div>
                                    <div style="font-size:.75rem;color:var(--hmo-text-3)">🔒 Akaun Peribadi</div>
                                </div>
                            </div>
                            <div class="menu-divider"></div>
                            <button class="menu-item" @onclick="CloseMenu"><span class="menu-icon">📋</span> Direktori</button>
                            @if (isAdmin) { <button class="menu-item" @onclick="GoToRls"><span class="menu-icon">🔐</span> Urus Akses</button> }
                            <div class="menu-divider"></div>
                            <button class="menu-item danger" @onclick="DoLogout"><span class="menu-icon">🚪</span> Log Keluar</button>
                            <div style="height:env(safe-area-inset-bottom,16px)"></div>
                        </div>
                    }
                </div>
            }
            else
            {
                <a href="/login" class="filled-btn" style="font-size:.82rem;padding:8px 22px"><i class="bi bi-box-arrow-in-right"></i> Log Masuk</a>
            }
        </div>
    </div>
</header>

@Body

<footer style="text-align:center;padding:16px 16px 80px;color:var(--hmo-text-3);font-size:.7rem;margin-top:24px;border-top:1px solid var(--hmo-border);background:var(--hmo-surface)">
    <span style="font-size:.6rem;opacity:.6">🔒 Semua tindakan direkodkan dalam audit trail</span>
</footer>

@if (isLoggedIn)
{
    <nav class="bottom-nav">
        <a href="/" class="bottom-nav-item"><i class="bi bi-people-fill nav-icon"></i> Direktori</a>
        <a href="/add" class="bottom-nav-item"><i class="bi bi-person-plus nav-icon"></i> Tambah</a>
        <button class="bottom-nav-item" @onclick="DoLogout" style="border:none;background:none;font-family:inherit;cursor:pointer"><i class="bi bi-box-arrow-right nav-icon"></i> Log Keluar</button>
    </nav>
}

@code {
    bool isLoggedIn; string? username; string initial = "?"; int avColor; bool showMenu; bool isAdmin;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var s = await Http.GetFromJsonAsync<AuthStatus>("api/auth/status");
            if (s?.IsAuthenticated == true)
            {
                isLoggedIn = true; username = s.Name;
                initial = string.IsNullOrWhiteSpace(s.Name) ? "?" : s.Name[0].ToString().ToUpper();
                avColor = Math.Abs(s.Name?.GetHashCode() ?? 0) % 10;
                isAdmin = s.IsAdmin;
                StateHasChanged();
            }
        }
        catch { }
    }

    void ToggleMenu() { showMenu = !showMenu; StateHasChanged(); }
    void CloseMenu() { showMenu = false; StateHasChanged(); }
    void GoToRls() { showMenu = false; Nav.NavigateTo("/admin/rls"); }
    async Task DoLogout() { showMenu = false; StateHasChanged(); await Http.PostAsync("api/auth/logout", null); Nav.NavigateTo("/login", forceLoad: true); }
}
