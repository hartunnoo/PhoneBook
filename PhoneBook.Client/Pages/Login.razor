@page "/login"
@rendermode InteractiveWebAssembly
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<div class="login-wrapper">
    <div class="login-split">
        @* Left: Brand panel *@
        <div class="login-brand">
            <div class="login-brand-content">
                <div class="login-logo">
                    <div class="login-logo-icon">📞</div>
                </div>
                <h1>PhoneBook</h1>
                <p>Direktori Pejabat Kerajaan</p>
                <div class="login-features">
                    <div class="login-feature"><i class="bi bi-shield-check"></i> Akses selamat & terjamin</div>
                    <div class="login-feature"><i class="bi bi-building"></i> Direktori Pejabat Kerajaan</div>
                    <div class="login-feature"><i class="bi bi-share"></i> Eksport ke WhatsApp</div>
                </div>
            </div>
        </div>

        @* Right: Form panel *@
        <div class="login-form-panel">
            <div class="login-form-inner">
                <div class="login-form-header">
                    <h2>Log Masuk</h2>
                    <p>Masukkan butiran akaun anda</p>
                </div>

                <EditForm Model="auth" OnValidSubmit="DoLogin" FormName="login">
                    <DataAnnotationsValidator />
                    <div class="login-field">
                        <div class="login-field-icon"><i class="bi bi-envelope"></i></div>
                        <input type="email" @bind="auth.Username" placeholder="Alamat emel atau username" autocomplete="username" />
                    </div>
                    <ValidationMessage For="()=>auth.Username" />

                    <div class="login-field">
                        <div class="login-field-icon"><i class="bi bi-lock"></i></div>
                        <input type="password" @bind="auth.Password" placeholder="Kata laluan" autocomplete="current-password" />
                    </div>
                    <ValidationMessage For="()=>auth.Password" />

                    @if (!string.IsNullOrEmpty(error))
                    { <div class="login-error"><i class="bi bi-exclamation-triangle-fill"></i> @error</div> }

                    <button type="submit" class="login-btn" disabled="@busy">@(busy ? "Sila tunggu..." : "Log Masuk") <i class="bi bi-arrow-right"></i></button>

                    <div class="login-divider"><span>atau</span></div>

                    <button type="button" class="login-btn-outline" @onclick="DoRegister" disabled="@busy">Daftar Akaun Baru</button>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@code {
    AuthForm auth = new(); bool busy; string? error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { var s = await Http.GetFromJsonAsync<AuthStatus>("api/auth/status"); if (s?.IsAuthenticated == true) Nav.NavigateTo("/"); } catch { }
    }

    async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(auth.Username) || string.IsNullOrWhiteSpace(auth.Password)) { error = "Sila isi semua ruangan"; return; }
        busy = true; error = null;
        try { var r = await Http.PostAsJsonAsync("api/auth/login", auth); if (r.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true); else error = "Username atau kata laluan tidak sah"; }
        catch { error = "Ralat sambungan. Sila cuba lagi."; }
        finally { busy = false; }
    }

    async Task DoRegister()
    {
        if (string.IsNullOrWhiteSpace(auth.Username) || string.IsNullOrWhiteSpace(auth.Password)) { error = "Sila isi semua ruangan"; return; }
        busy = true; error = null;
        try { var r = await Http.PostAsJsonAsync("api/auth/register", auth); if (r.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true); else { var e = await r.Content.ReadFromJsonAsync<ErrorResponse>(); error = e?.Errors?.FirstOrDefault() ?? "Pendaftaran gagal"; } }
        catch { error = "Ralat sambungan."; }
        finally { busy = false; }
    }

    class AuthForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Username { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string Password { get; set; } = "";
    }
    record AuthStatus(bool IsAuthenticated, string? Name);
    record ErrorResponse(string? Message, string[]? Errors);
}
