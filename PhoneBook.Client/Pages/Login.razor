@page "/login"
@rendermode InteractiveWebAssembly
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<div class="md-login-page">
    <div class="md-login-card">
        <div class="md-login-header">
            <div class="md-login-icon"><i class="bi bi-person-badge" style="font-size:2.5rem;color:var(--md-on-surface-variant)"></i></div>
            <h1>Log masuk</h1>
            <p class="md-login-subtitle">Untuk meneruskan ke PhoneBook</p>
        </div>

        <EditForm Model="auth" OnValidSubmit="DoLogin" FormName="login">
            <DataAnnotationsValidator />
            <div class="md-text-field @(usernameError ? "error" : "")">
                <input type="email" @bind="auth.Username" placeholder=" " id="user" autocomplete="username" />
                <label for="user">Alamat emel atau username</label>
                @if (usernameError) { <div class="md-error-text">Diperlukan</div> }
            </div>
            <div class="md-text-field @(passwordError ? "error" : "")">
                <input type="password" @bind="auth.Password" placeholder=" " id="pass" autocomplete="current-password" />
                <label for="pass">Kata laluan</label>
                @if (passwordError) { <div class="md-error-text">Diperlukan</div> }
            </div>
            @if (!string.IsNullOrEmpty(error))
            { <div style="background:var(--md-sys-color-error-container);padding:8px 16px;border-radius:8px;font-size:0.8rem;color:var(--md-sys-color-error);margin-bottom:16px">⚠️ @error</div> }
            <div class="d-flex justify-content-between align-items-center mt-2">
                <button type="button" class="md-text-btn" @onclick="DoRegister">Buat akaun</button>
                <button type="submit" class="md-filled-btn" disabled="@busy">Seterusnya</button>
            </div>
        </EditForm>
    </div>
    <p style="font-size:0.75rem;color:var(--md-sys-color-on-surface-muted);margin-top:16px">🔒 Maklumat anda selamat</p>
</div>

@code {
    AuthForm auth = new(); bool busy; string? error; bool usernameError; bool passwordError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { var s = await Http.GetFromJsonAsync<AuthStatus>("api/auth/status"); if (s?.IsAuthenticated == true) Nav.NavigateTo("/"); } catch { }
    }

    async Task DoLogin()
    {
        usernameError = string.IsNullOrWhiteSpace(auth.Username);
        passwordError = string.IsNullOrWhiteSpace(auth.Password);
        if (usernameError || passwordError) return;

        busy = true; error = null;
        try { var r = await Http.PostAsJsonAsync("api/auth/login", auth); if (r.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true); else error = "Emel atau kata laluan salah"; }
        catch { error = "Ralat sambungan"; }
        finally { busy = false; }
    }

    async Task DoRegister()
    {
        usernameError = string.IsNullOrWhiteSpace(auth.Username);
        passwordError = string.IsNullOrWhiteSpace(auth.Password);
        if (usernameError || passwordError) return;

        busy = true; error = null;
        try { var r = await Http.PostAsJsonAsync("api/auth/register", auth); if (r.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true); else { var e = await r.Content.ReadFromJsonAsync<ErrorResponse>(); error = e?.Errors?.FirstOrDefault() ?? "Pendaftaran gagal"; } }
        catch { error = "Ralat sambungan"; }
        finally { busy = false; }
    }

    class AuthForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Username { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string Password { get; set; } = "";
    }
    record AuthStatus(bool IsAuthenticated, string? Name);
    record ErrorResponse(string? Message, string[]? Errors);
}
