@page "/login"
@rendermode InteractiveWebAssembly
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<div class="login-wrapper">
    <div class="login-split">
        @* Left: Brand panel *@
        <div class="login-brand">
            <div class="login-brand-content">
                <div class="login-badge">🔐 SISTEM RASMI KERAJAAN</div>
                <div class="login-logo">
                    <div class="login-logo-icon">
                        <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="5"/><line x1="8" y1="9" x2="16" y2="9" stroke-linecap="round"/><line x1="8" y1="13" x2="16" y2="13" stroke-linecap="round"/><line x1="8" y1="17" x2="12" y2="17" stroke-linecap="round"/></svg>
                    </div>
                </div>
                <h1><span style="color:#c9a43b">CIS</span></h1>
                <p class="brand-tagline">Centralise Information System</p>
                <div style="display:flex;gap:6px;flex-wrap:wrap;justify-content:center;margin-bottom:20px">
                    <span class="badge" style="background:rgba(201,164,59,.15);color:#debd5a;font-size:.58rem;padding:3px 8px;border:1px solid rgba(201,164,59,.2)">👑 VVIP</span>
                    <span class="badge" style="background:rgba(201,164,59,.1);color:#c9a43b;font-size:.58rem;padding:3px 8px;border:1px solid rgba(201,164,59,.15)">⭐ VIP</span>
                    <span class="badge" style="background:rgba(99,102,241,.15);color:#a5b4fc;font-size:.58rem;padding:3px 8px;border:1px solid rgba(99,102,241,.2)">🤖 AI</span>
                    <span class="badge" style="background:rgba(34,197,94,.15);color:#86efac;font-size:.58rem;padding:3px 8px;border:1px solid rgba(34,197,94,.2)">💬 WA</span>
                </div>
                <div class="brand-features">
                    <div>🔐 Akses Selamat & Terjamin</div>
                    <div>🤖 Carian Pintar Berkuasa AI</div>
                    <div>📤 Eksport Direktori ke WhatsApp</div>
                    <div>📊 Audit Trail & Pemantauan</div>
                </div>
            </div>
            <div class="brand-credit">SSCU, ITD, Istana Nurul Iman</div>
        </div>

        @* Right: Form panel *@
        <div class="login-form-panel">
            <div class="login-form-inner">
                <div class="login-form-header">
                    <h2>Log Masuk</h2>
                    <p>Sila masukkan butiran akaun rasmi anda</p>
                </div>

                <div class="login-warning">
                    <div class="warning-header">
                        <span class="warning-icon">🛡️</span>
                        <span class="warning-title">⚠️ RESTRICTED ACCESS — AKSES TERHAD</span>
                    </div>
                    <div class="warning-badges">
                        <span>📜 Audit Trail</span>
                        <span>🆔 ID Direkodkan</span>
                        <span>📝 Semua Dilog</span>
                        <span>👁️ Dipantau</span>
                        <span>🔐 Dienkripsi</span>
                    </div>
                </div>

                <EditForm Model="auth" OnValidSubmit="DoLogin" FormName="login">
                    <DataAnnotationsValidator />
                    <div class="login-field">
                        <div class="login-field-icon"><i class="bi bi-envelope-fill"></i></div>
                        <input type="email" @bind="auth.Username" placeholder="Alamat emel rasmi" autocomplete="username" />
                    </div>
                    <ValidationMessage For="()=>auth.Username" />

                    <div class="login-field">
                        <div class="login-field-icon"><i class="bi bi-shield-lock-fill"></i></div>
                        <input type="password" @bind="auth.Password" placeholder="Kata laluan" autocomplete="current-password" />
                    </div>
                    <ValidationMessage For="()=>auth.Password" />

                    @if (!string.IsNullOrEmpty(error))
                    { <div class="login-error"><i class="bi bi-exclamation-triangle-fill"></i> @error</div> }

                    <button type="submit" class="login-btn" disabled="@busy">
                        <span>@(busy ? "Sila Tunggu..." : "Log Masuk")</span>
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </EditForm>

                <p class="login-footer-note">
                    <i class="bi bi-shield-check"></i> Semua aktiviti direkodkan untuk tujuan keselamatan
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    AuthForm auth = new(); bool busy; string? error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { var s = await Http.GetFromJsonAsync<AuthStatus>("api/auth/status"); if (s?.IsAuthenticated == true) Nav.NavigateTo("/"); } catch { }
    }

    async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(auth.Username) || string.IsNullOrWhiteSpace(auth.Password)) { error = "Sila isi semua ruangan"; return; }
        busy = true; error = null;
        try { var r = await Http.PostAsJsonAsync("api/auth/login", auth); if (r.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true); else error = "Username atau kata laluan tidak sah"; }
        catch { error = "Ralat sambungan. Sila cuba lagi."; }
        finally { busy = false; }
    }

    async Task DoRegister()
    {
        if (string.IsNullOrWhiteSpace(auth.Username) || string.IsNullOrWhiteSpace(auth.Password)) { error = "Sila isi semua ruangan"; return; }
        busy = true; error = null;
        try { var r = await Http.PostAsJsonAsync("api/auth/register", auth); if (r.IsSuccessStatusCode) Nav.NavigateTo("/", forceLoad: true); else { var e = await r.Content.ReadFromJsonAsync<ErrorResponse>(); error = e?.Errors?.FirstOrDefault() ?? "Pendaftaran gagal"; } }
        catch { error = "Ralat sambungan."; }
        finally { busy = false; }
    }

    class AuthForm
    {
        [System.ComponentModel.DataAnnotations.Required] public string Username { get; set; } = "";
        [System.ComponentModel.DataAnnotations.Required] public string Password { get; set; } = "";
    }
    record AuthStatus(bool IsAuthenticated, string? Name);
    record ErrorResponse(string? Message, string[]? Errors);
}
