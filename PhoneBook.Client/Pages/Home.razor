@page "/"
@rendermode InteractiveWebAssembly
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS

<div class="search-bar">
    <i class="bi bi-search" style="font-size:1.2rem;color:var(--md-on-surface-variant)"></i>
    <input @bind="search" @bind:event="oninput" @onkeyup="OnSearch" placeholder="Cari kenalan..." />
    @if (!string.IsNullOrWhiteSpace(search))
    { <button class="icon-btn" style="width:32px;height:32px;font-size:1rem" @onclick="ClearSearch"><i class="bi bi-x-lg"></i></button> }
    <span class="badge rounded-pill bg-primary ms-1">@(contacts?.Count ?? 0)</span>
    <a href="@GetFirstShareUrl()" target="_blank" style="display:inline-flex!important;align-items:center;gap:6px;padding:8px 16px!important;background:#25d366!important;color:#fff!important;font-weight:700!important;font-size:.85rem!important;border-radius:40px!important;text-decoration:none!important;box-shadow:0 2px 8px rgba(37,211,102,.4)!important"><i class="bi bi-whatsapp"></i> EKSPORT WA</a>
    <button class="icon-btn" @onclick="ExportAll" title="Eksport CSV"><i class="bi bi-download"></i></button>
    <button class="icon-btn ms-1" @onclick="ToggleDarkMode" title="Dark mode" style="width:32px;height:32px"><i class="bi @(darkMode ? "bi-sun-fill" : "bi-moon-fill")"></i></button>
    <button class="icon-btn" @onclick="ToggleCsvImport" title="Import CSV"><i class="bi bi-upload"></i></button>
</div>

@* ── STATS BAR ── *@
@if (stats is not null)
{
    <div class="stats-dash">
        <div class="stat-mini" style="cursor:pointer" @onclick="ClearFilter"><div class="stat-num">@stats.Total</div><div class="stat-label">Jumlah</div></div>
        <div class="stat-mini" style="cursor:pointer" @onclick="FilterFav"><div class="stat-num">⭐ @stats.Favorites</div><div class="stat-label">Favorit</div></div>
        @foreach (var m in stats.Ministries.Take(3))
        { <div class="stat-mini" style="cursor:pointer" @onclick="() => FilterMinistry(m.Name)"><div class="stat-num" style="font-size:1rem">@m.Count</div><div class="stat-label">@m.Name</div></div> }
        @if (!string.IsNullOrEmpty(filter))
        { <div class="stat-mini" style="cursor:pointer;background:var(--md-primary-container)" @onclick="ClearFilter"><div class="stat-label">✕ Tapis: @filter</div></div> }
    </div>
}

@* ── CSV IMPORT ── *@
@if (showCsvImport)
{
    <div class="scrim" @onclick="()=>showCsvImport=false">
        <div class="dialog" @onclick:stopPropagation>
            <h3>📥 Import CSV</h3>
            <p>Format: Name, Mobile, Email, Jawatan, Kementerian</p>
            <input type="file" accept=".csv" @onchange="OnCsvSelected" />
            @if (csvBusy) { <div class="spinner mt-2"></div> }
            @if (!string.IsNullOrEmpty(csvMsg)) { <div class="mt-2" style="font-size:.8rem;color:var(--md-primary)">@csvMsg</div> }
        </div>
    </div>
}

@if (contacts is null)
{ <div class="loading-state"><div class="spinner"></div><p>Memuat...</p></div> }
else if (!contacts.Any())
{
    <div class="empty-state">
        <div class="empty-icon"><i class="bi bi-person-plus" style="font-size:2.5rem;color:var(--md-on-surface-variant)"></i></div>
        <h2>Tiada kenalan</h2>
        <p>Tambahkan kenalan untuk bermula</p>
        <button class="filled-btn" @onclick="() => Nav.NavigateTo(Routes.Add)"><i class="bi bi-plus-lg"></i> Tambah kenalan</button>
    </div>
}
else
{
    @* View toggle *@
    <div style="display:flex;justify-content:flex-end;padding:4px 16px;gap:4px">
        <button class="icon-btn @(viewMode=="grid"?"active":"")" style="width:36px;height:36px" @onclick="SetGrid" title="Grid"><i class="bi bi-grid-3x3-gap-fill"></i></button>
        <button class="icon-btn @(viewMode=="list"?"active":"")" style="width:36px;height:36px" @onclick="SetList" title="List"><i class="bi bi-list-ul"></i></button>
    </div>

    @* Letter index *@
    @if (viewMode == "list")
    {
        char? lastLetter = null;
        <div class="contact-list">
            @{
                var sorted = contacts.OrderByDescending(c => c.IsFavorite).ThenBy(c => c.Name).ToList();
            }
            @foreach (var c in sorted)
            {
                var letter = char.ToUpper(c.Name[0]);
                if (c.IsFavorite && lastLetter != '★')
                { <div class="alpha-header" style="background:linear-gradient(90deg,rgba(245,158,11,.1),rgba(239,68,68,.06));color:#f59e0b">⭐ Favorit (@sorted.Count(x=>x.IsFavorite))</div> lastLetter = '★'; }
                else if (!c.IsFavorite && letter != lastLetter)
                { <div class="alpha-header">@letter</div> lastLetter = letter; }
                var ac = Math.Abs(c.Name.GetHashCode()) % 10;
                <div class="contact-list-item" @onclick="() => Edit(c.Id)">
                    <input type="checkbox" checked="@selected.Contains(c.Id)" @onchange="() => ToggleSelect(c)" @onclick:stopPropagation style="width:16px;height:16px;cursor:pointer;accent-color:var(--hmo-gold);flex-shrink:0" />
                    <div class="avatar acac" style="width:36px;height:36px;font-size:.85rem">
                        @if (!string.IsNullOrWhiteSpace(c.PhotoPath)){<img src="@c.PhotoPath" alt="@c.Name"/>}else if (c.Gender == "female"){<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" opacity=".6"><circle cx="12" cy="6" r="4"/><path d="M12 12c-3 0-9 1.5-9 4.5V18c0 .6.4 1 1 1h4l1.5-3h5l1.5 3h4c.6 0 1-.4 1-1v-1.5c0-3-6-4.5-9-4.5z"/></svg>}else{<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" opacity=".6"><circle cx="12" cy="6" r="4"/><path d="M15 12H9c-4 0-7 2-7 5.5V19c0 .6.4 1 1 1h18c.6 0 1-.4 1-1v-1.5c0-3.5-3-5.5-7-5.5z"/></svg>}
                    </div>
                    <div class="contact-main">
                        <div style="font-size:.9rem;font-weight:500;line-height:1.3">
                            @if(!string.IsNullOrWhiteSpace(c.Honorific)){<span class="badge bg-primary bg-opacity-10 text-primary me-1" style="font-size:.6rem;padding:1px 5px">@c.Honorific</span>}
                            @c.Name
                        </div>
                        <div class="contact-meta">
                            @if(!string.IsNullOrWhiteSpace(c.Jawatan)){<span>@c.Jawatan</span>}
                            @if(!string.IsNullOrWhiteSpace(c.Kementerian)){<span> · @c.Kementerian</span>}
                            @if(!string.IsNullOrWhiteSpace(c.Department)){<span> · @c.Department</span>}
                            @if(!string.IsNullOrWhiteSpace(c.Building)){<span> · @c.Building</span>}
                            @if(!string.IsNullOrWhiteSpace(c.PAName)){<span> · 👔 @c.PAName</span>}
                        </div>
                        @if (!string.IsNullOrWhiteSpace(c.Tags))
                        {
                            <div style="margin-top:2px">
                                @foreach (var tag in c.Tags.Split(',').Select(t => t.Trim()).Where(t => !string.IsNullOrEmpty(t)))
                                { <span class="tag-pill" @onclick="() => FilterTag(tag)" @onclick:stopPropagation style="cursor:pointer">@tag</span> }
                            </div>
                        }
                    </div>
                    <div class="contact-actions">
                        <button class="fav-star @(c.IsFavorite?"active":"")" @onclick="() => ToggleFav(c)" @onclick:stopPropagation><i class="bi @(c.IsFavorite?"bi-star-fill":"bi-star")"></i></button>
                        @if(!string.IsNullOrWhiteSpace(c.Mobile1)){<a href="@WhatsAppUrl(c.Mobile1)" target="_blank" class="chip wa" @onclick:stopPropagation><i class="bi bi-whatsapp"></i> Chat WA</a>}
                        <a href="@GetShareUrl(c)" target="_blank" class="chip wa" @onclick:stopPropagation title="Hantar detail ke WhatsApp" style="background:#075e54;color:#fff"><i class="bi bi-share-fill"></i> Detail</a>
                        <a href="/api/contacts/@c.Id/vcard" class="chip vcard" @onclick:stopPropagation><i class="bi bi-download"></i> vCard</a>
                        <button class="icon-btn danger" style="width:30px;height:30px" @onclick="() => ConfirmDelete(c)" @onclick:stopPropagation><i class="bi bi-trash3"></i></button>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="contact-grid">
            @foreach (var c in contacts.OrderBy(c => c.Name))
            {
                var ac = Math.Abs(c.Name.GetHashCode()) % 10;
                <div class="contact-tile" @onclick="() => Edit(c.Id)">
                    <div class="avatar lg acac">
                        @if (!string.IsNullOrWhiteSpace(c.PhotoPath)){<img src="@c.PhotoPath" alt="@c.Name"/>}else if (c.Gender == "female"){<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" opacity=".6"><circle cx="12" cy="6" r="4"/><path d="M12 12c-3 0-9 1.5-9 4.5V18c0 .6.4 1 1 1h4l1.5-3h5l1.5 3h4c.6 0 1-.4 1-1v-1.5c0-3-6-4.5-9-4.5z"/></svg>}else{<svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" opacity=".6"><circle cx="12" cy="6" r="4"/><path d="M15 12H9c-4 0-7 2-7 5.5V19c0 .6.4 1 1 1h18c.6 0 1-.4 1-1v-1.5c0-3.5-3-5.5-7-5.5z"/></svg>}
                    </div>
                    <div class="tile-name">
                        @if(!string.IsNullOrWhiteSpace(c.Honorific)){<span style="font-size:.6rem;opacity:.7">@c.Honorific </span>}
                        @c.Name
                    </div>
                    @if (!string.IsNullOrWhiteSpace(c.Jawatan)) {<div class="tile-sub">@c.Jawatan</div>}
                    @if (!string.IsNullOrWhiteSpace(c.Kementerian)) {<div class="tile-sub" style="font-size:.6rem">@c.Kementerian</div>}
                </div>
            }
        </div>
    }
}

@* FAB *@
@if (contacts is not null)
{ <button class="fab" @onclick="() => Nav.NavigateTo(Routes.Add)"><i class="bi bi-plus-lg"></i></button> }

@* TOAST *@
@if (toast is not null)
{
    <div class="toast-container"><div class="toast @(toast.IsError?"toast-error":"toast-success")">
        <i class="bi @(toast.IsError?"bi-exclamation-triangle-fill":"bi-check-circle-fill")"></i>
        <span>@toast.Message</span>
        <button class="toast-close" @onclick="()=>toast=null"><i class="bi bi-x"></i></button>
    </div></div>
}

@* Delete Dialog *@
@if (deleteTarget is not null)
{
    <div class="scrim" @onclick="CancelDelete">
        <div class="dialog" @onclick:stopPropagation>
            <h3>Padam kenalan?</h3>
            <p>@deleteTarget.Name akan dipadamkan kekal.</p>
            <div class="dialog-actions">
                <button class="text-btn" @onclick="CancelDelete">Batal</button>
                <button class="filled-btn" style="background:var(--md-error)" @onclick="DoDelete">Padam</button>
            </div>
        </div>
    </div>
}

@code {
    List<ContactDto>? contacts; string search = ""; string viewMode = "list"; string filter = ""; string sortBy = "fav"; ContactDto? deleteTarget; Timer? debounce; ToastInfo? toast;
    HashSet<int> selected = new();
    StatsDto? stats; bool darkMode; bool showCsvImport; bool csvBusy; string? csvMsg;

    class ToastInfo { public string Message { get; set; } = ""; public bool IsError { get; set; } }
    void ShowToast(string msg, bool err) { toast = new ToastInfo { Message = msg, IsError = err }; StateHasChanged(); _ = DismissToast(); }
    async Task DismissToast() { await Task.Delay(3000); toast = null; StateHasChanged(); }
    static class Routes { public const string Add = "/add"; public static string Edit(int id) => $"/edit/{id}"; }
    const string ApiBase = "api/contacts";

    protected override async Task OnAfterRenderAsync(bool firstRender) { if (firstRender) { await Load(); await LoadStats(); } }

    async Task Load()
    {
        try {
            var url = ApiBase + $"?sort={sortBy}&pageSize=200";
            if (!string.IsNullOrWhiteSpace(search)) url += $"&search={Uri.EscapeDataString(search)}";
            contacts = await Http.GetFromJsonAsync<List<ContactDto>>(url) ?? new();
            if (filter == "fav") contacts = contacts.Where(c => c.IsFavorite).ToList();
            else if (filter.StartsWith("tag:")) { var tag = filter[4..]; contacts = contacts.Where(c => c.Tags != null && c.Tags.Contains(tag, StringComparison.OrdinalIgnoreCase)).ToList(); }
            else if (!string.IsNullOrEmpty(filter)) contacts = contacts.Where(c => c.Kementerian == filter).ToList();
            StateHasChanged();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized) { Nav.NavigateTo("/login"); }
        catch { contacts ??= new(); }
    }

    async Task LoadStats() { try { stats = await Http.GetFromJsonAsync<StatsDto>(ApiBase + "/stats"); StateHasChanged(); } catch { } }

    void ToggleDarkMode() { darkMode = !darkMode; StateHasChanged(); }

    async Task ToggleFav(ContactDto c) { try { var r = await Http.PutAsync($"{ApiBase}/{c.Id}/favorite", null); if (r.IsSuccessStatusCode) { c.IsFavorite = !c.IsFavorite; ShowToast(c.IsFavorite ? "⭐ Ditanda favorit" : "Favorit dibuang", false); } } catch { } }

    void ToggleCsvImport() => showCsvImport = !showCsvImport;

    async Task OnCsvSelected(ChangeEventArgs e)
    {
        var files = e.Value as Microsoft.AspNetCore.Components.Forms.IBrowserFile[]; if (files is null or { Length: 0 }) return;
        var file = files[0]; csvBusy = true; csvMsg = null; StateHasChanged();
        try { using var content = new MultipartFormDataContent(); var stream = file.OpenReadStream(10*1024*1024); content.Add(new StreamContent(stream), "file", file.Name); var r = await Http.PostAsync(ApiBase + "/import", content); if (r.IsSuccessStatusCode) { var d = await r.Content.ReadFromJsonAsync<ImportResult>(); csvMsg = $"✅ {d?.Count ?? 0} kenalan diimport"; await Load(); await LoadStats(); } else csvMsg = "❌ Gagal import"; }
        catch { csvMsg = "❌ Ralat"; }
        finally { csvBusy = false; StateHasChanged(); }
    }

    void SetGrid() => viewMode = "grid"; void SetList() => viewMode = "list";
    void ClearSearch() { search = ""; filter = ""; selected.Clear(); _ = Load(); }
    void ClearFilter() { filter = ""; _ = Load(); }
    void FilterFav() { filter = "fav"; _ = Load(); }
    void FilterMinistry(string name) { filter = name; _ = Load(); }
    void FilterTag(string tag) { filter = $"tag:{tag}"; search = ""; _ = Load(); }
    void OnSearch(KeyboardEventArgs e) { debounce?.Dispose(); debounce = new Timer(async _ => { await InvokeAsync(Load); }, null, 250, Timeout.Infinite); }

    void ToggleSelect(ContactDto c) { if (selected.Contains(c.Id)) selected.Remove(c.Id); else selected.Add(c.Id); StateHasChanged(); }

    async Task BulkDelete()
    {
        if (!selected.Any()) return;
        try { await Http.PostAsJsonAsync(ApiBase + "/bulk-delete", selected.ToArray()); ShowToast($"✅ {selected.Count} kenalan dipadam", false); selected.Clear(); await Load(); await LoadStats(); }
        catch { ShowToast("❌ Gagal", true); }
    }

    async Task ExportAllToWA()
    {
        if (contacts is null || !contacts.Any()) return;
        var sb = new System.Text.StringBuilder();
        sb.AppendLine($"SENARAI KENALAN ({contacts.Count})");
        sb.AppendLine("--------------------");
        foreach (var c in contacts.OrderBy(c => c.Name))
        {
            var h = !string.IsNullOrWhiteSpace(c.Honorific) ? c.Honorific + " " : "";
            sb.AppendLine($"{h}{c.Name}");
            if (!string.IsNullOrWhiteSpace(c.Jawatan)) sb.AppendLine($"  Jawatan: {c.Jawatan}");
            if (!string.IsNullOrWhiteSpace(c.Kementerian)) sb.AppendLine($"  Kementerian: {c.Kementerian}");
            if (!string.IsNullOrWhiteSpace(c.Mobile1)) sb.AppendLine($"  Mobile: {c.Mobile1}");
            if (!string.IsNullOrWhiteSpace(c.Phone1)) sb.AppendLine($"  Telefon: {c.Phone1}");
            if (!string.IsNullOrWhiteSpace(c.Email1)) sb.AppendLine($"  Emel: {c.Email1}");
            sb.AppendLine();
        }
        sb.AppendLine("--------------------");
        sb.AppendLine("PhoneBook HMO | SSCU, ITD, Istana Nurul Iman");
        var text = sb.ToString();
        Nav.NavigateTo("https://wa.me/?text=" + Uri.EscapeDataString(text), forceLoad: false);
        ShowToast("✅ Membuka WhatsApp...", false);
    }

    async Task ExportAll()
    {
        try { Nav.NavigateTo(ApiBase + "/export", forceLoad: false); ShowToast("✅ CSV dimuat turun", false); }
        catch { ShowToast("❌ Gagal eksport", true); }
    }
    static string WhatsAppUrl(string? n) => string.IsNullOrWhiteSpace(n) ? "#" : $"https://wa.me/{new string(n.Where(c => char.IsDigit(c) || c == '+').ToArray())}";

    string BuildContactText(ContactDto c)
    {
        var sb = new System.Text.StringBuilder();
        var honorific = !string.IsNullOrWhiteSpace(c.Honorific) ? c.Honorific + " " : "";
        sb.AppendLine($"{honorific}{c.Name}");
        if (!string.IsNullOrWhiteSpace(c.Jawatan)) sb.AppendLine($"Jawatan: {c.Jawatan}");
        if (!string.IsNullOrWhiteSpace(c.Kementerian)) sb.AppendLine($"Kementerian: {c.Kementerian}");
        if (!string.IsNullOrWhiteSpace(c.Department)) sb.AppendLine($"Jabatan: {c.Department}");
        if (!string.IsNullOrWhiteSpace(c.Bahagian)) sb.AppendLine($"Bahagian: {c.Bahagian}");
        if (!string.IsNullOrWhiteSpace(c.Building))
        {
            var loc = c.Building;
            if (!string.IsNullOrWhiteSpace(c.Floor)) loc += $", Tkt {c.Floor}";
            if (!string.IsNullOrWhiteSpace(c.Room)) loc += $", Blk {c.Room}";
            sb.AppendLine($"Lokasi: {loc}");
        }
        var mobs = new[] { c.Mobile1, c.Mobile2, c.Mobile3, c.Mobile4 }.Where(m => !string.IsNullOrWhiteSpace(m)).ToList();
        var phs = new[] { c.Phone1, c.Phone2, c.Phone3, c.Phone4 }.Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
        var ems = new[] { c.Email1, c.Email2, c.Email3 }.Where(e => !string.IsNullOrWhiteSpace(e)).ToList();
        if (mobs.Any()) { sb.AppendLine(); foreach (var m in mobs) sb.AppendLine($"Mobile: {m}"); }
        foreach (var p in phs) sb.AppendLine($"Telefon: {p}");
        foreach (var e in ems) sb.AppendLine($"Emel: {e}");
        if (!string.IsNullOrWhiteSpace(c.PAName))
        {
            sb.AppendLine(); sb.AppendLine($"PA: {c.PAName}");
            if (!string.IsNullOrWhiteSpace(c.PAMobile)) sb.AppendLine($"PA Mobile: {c.PAMobile}");
        }
        return sb.ToString().TrimEnd();
    }

    string GetFirstShareUrl()
    {
        if (contacts is not null && contacts.Any())
            return GetShareUrl(contacts.OrderBy(c => c.Name).First());
        return "https://wa.me/?text=Sila%20tunggu%20kenalan%20dimuatkan";
    }

    string GetShareUrl(ContactDto c)
    {
        var text = BuildContactText(c);
        return "https://wa.me/?text=" + Uri.EscapeDataString(text);
    }

    void ShareToWA(ContactDto c)
    {
        Nav.NavigateTo(GetShareUrl(c), forceLoad: false);
    }
    void Edit(int id) => Nav.NavigateTo(Routes.Edit(id));
    void ConfirmDelete(ContactDto c) => deleteTarget = c; void CancelDelete() => deleteTarget = null;
    async Task DoDelete() { if (deleteTarget is null) return; try { await Http.DeleteAsync($"{ApiBase}/{deleteTarget.Id}"); ShowToast("✅ " + deleteTarget.Name + " dipadam", false); } catch { ShowToast("❌ Gagal memadam", true); } deleteTarget = null; await Load(); }

    class ContactDto { public int Id { get; set; } public string Name { get; set; } = ""; public string? Gender { get; set; } public string? Honorific { get; set; } public string? Jawatan { get; set; } public string? Department { get; set; } public string? Bahagian { get; set; } public string? Kementerian { get; set; } public string? Company { get; set; } public string? Building { get; set; } public string? Floor { get; set; } public string? Room { get; set; } public string? PAName { get; set; } public string? PAMobile { get; set; } public string? PAEmail { get; set; } public string? Mobile1 { get; set; } public string? Mobile2 { get; set; } public string? Mobile3 { get; set; } public string? Mobile4 { get; set; } public string? Phone1 { get; set; } public string? Phone2 { get; set; } public string? Phone3 { get; set; } public string? Phone4 { get; set; } public string? Email1 { get; set; } public string? Email2 { get; set; } public string? Email3 { get; set; } public string? Tags { get; set; } public bool IsFavorite { get; set; } public string? Notes { get; set; } public string? PhotoPath { get; set; } }
    class StatsDto { public int Total { get; set; } public int Favorites { get; set; } public List<MinistryCount> Ministries { get; set; } = new(); }
    class MinistryCount { public string Name { get; set; } = ""; public int Count { get; set; } }
    record ImportResult(int Count);
}
