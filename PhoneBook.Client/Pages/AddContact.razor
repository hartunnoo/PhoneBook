@page "/add"
@rendermode InteractiveWebAssembly
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Nav

<div class="top-bar-content" style="padding:8px 0">
    <h1 style="font-size:1.75rem;font-weight:400;margin:0">➕ Tambah Direktori</h1>
    <a href="/" class="outlined-btn"><i class="bi bi-arrow-left"></i> Kembali</a>
</div>

<EditForm Model="c" OnValidSubmit="Save" FormName="add">
    <DataAnnotationsValidator />

    @* ── PROFILE ── *@
    @* ── AI AUTO-PARSE ── *@
    <div class="card-form" style="margin-bottom:12px">
        <div class="card-form-header" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff"><h3>🤖 AI Auto-Isi</h3></div>
        <div class="card-form-body">
            <textarea @bind="pasteText" class="form-control-enterprise" rows="3" placeholder="Tampal email signature atau teks kad bisnes di sini..." style="font-size:.8rem"></textarea>
            <div class="d-flex gap-2 mt-2 align-items-center">
                <button class="chip" style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;font-weight:600" @onclick="ParseText" disabled="@aiBusy">
                    <i class="bi bi-robot"></i> @(aiBusy ? "Memproses..." : "Parse & Isi")
                </button>
                @if (!string.IsNullOrEmpty(aiMsg)) { <small class="@(aiMsg.Contains("✅")?"":"text-danger")">@aiMsg</small> }
            </div>
        </div>
    </div>

    <div class="form-section">
        <div class="form-section-title"><i class="bi bi-person-vcard"></i> Maklumat Peribadi</div>
        <div class="text-field">
            <InputText @bind-Value="c.Honorific" placeholder=" " id="hn" /><label for="hn">Gelaran (YB, YM, Dato, etc.)</label>
        </div>
        <div class="text-field">
            <InputText @bind-Value="c.Name" placeholder=" " id="nm" /><label for="nm">Nama *</label>
            <ValidationMessage For="()=>c.Name" />
        </div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
            <div class="text-field"><InputText @bind-Value="c.Jawatan" placeholder=" " id="jw" /><label for="jw">Jawatan</label></div>
            <div class="text-field"><InputText @bind-Value="c.Company" placeholder=" " id="co" /><label for="co">Syarikat</label></div>
        </div>
    </div>

    @* ── ORGANISASI ── *@
    <div class="form-section">
        <div class="form-section-title"><i class="bi bi-building"></i> Organisasi</div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
            <div class="text-field"><InputText @bind-Value="c.Kementerian" placeholder=" " id="km" /><label for="km">Kementerian</label></div>
            <div class="text-field"><InputText @bind-Value="c.Department" placeholder=" " id="dp" /><label for="dp">Jabatan</label></div>
        </div>
        <div class="text-field"><InputText @bind-Value="c.Bahagian" placeholder=" " id="bh" /><label for="bh">Bahagian</label></div>
    </div>

    @* ── OFFICE ── *@
    <div class="form-section">
        <div class="form-section-title"><i class="bi bi-geo-alt"></i> Lokasi Pejabat</div>
        <div class="text-field"><InputText @bind-Value="c.Building" placeholder=" " id="bd" /><label for="bd">Bangunan</label></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
            <div class="text-field"><InputText @bind-Value="c.Floor" placeholder=" " id="fl" /><label for="fl">Tingkat</label></div>
            <div class="text-field"><InputText @bind-Value="c.Room" placeholder=" " id="rm" /><label for="rm">Bilik</label></div>
        </div>
    </div>

    @* ── PA / SECRETARY ── *@
    <div class="form-section">
        <div class="form-section-title"><i class="bi bi-person-badge"></i> Setiausaha / PA</div>
        <div class="text-field"><InputText @bind-Value="c.PAName" placeholder=" " id="pa" /><label for="pa">Nama PA</label></div>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
            <div class="text-field"><InputText @bind-Value="c.PAMobile" placeholder=" " id="pam" /><label for="pam">Mobile PA</label></div>
            <div class="text-field"><InputText @bind-Value="c.PAEmail" placeholder=" " id="pae" /><label for="pae">Emel PA</label></div>
        </div>
    </div>

    @* ── PHONES ── *@
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0">
        <div class="form-section">
            <div class="form-section-title"><i class="bi bi-phone"></i> Mobile</div>
            <div class="text-field"><InputText @bind-Value="c.Mobile1" placeholder=" " id="m1" /><label for="m1">Mobile 1 (WhatsApp)</label></div>
            <div class="text-field"><InputText @bind-Value="c.Mobile2" placeholder=" " id="m2" /><label for="m2">Mobile 2</label></div>
            <div class="text-field"><InputText @bind-Value="c.Mobile3" placeholder=" " id="m3" /><label for="m3">Mobile 3</label></div>
            <div class="text-field"><InputText @bind-Value="c.Mobile4" placeholder=" " id="m4" /><label for="m4">Mobile 4</label></div>
        </div>
        <div class="form-section">
            <div class="form-section-title"><i class="bi bi-telephone"></i> Telefon</div>
            <div class="text-field"><InputText @bind-Value="c.Phone1" placeholder=" " id="p1" /><label for="p1">Telefon 1</label></div>
            <div class="text-field"><InputText @bind-Value="c.Phone2" placeholder=" " id="p2" /><label for="p2">Telefon 2</label></div>
            <div class="text-field"><InputText @bind-Value="c.Phone3" placeholder=" " id="p3" /><label for="p3">Telefon 3</label></div>
            <div class="text-field"><InputText @bind-Value="c.Phone4" placeholder=" " id="p4" /><label for="p4">Telefon 4</label></div>
        </div>
    </div>

    @* ── EMAILS ── *@
    <div class="form-section">
        <div class="form-section-title"><i class="bi bi-envelope"></i> Emel</div>
        <div class="text-field"><InputText @bind-Value="c.Email1" placeholder=" " id="e1" /><label for="e1">Emel 1</label></div>
        <div class="text-field"><InputText @bind-Value="c.Email2" placeholder=" " id="e2" /><label for="e2">Emel 2</label></div>
        <div class="text-field"><InputText @bind-Value="c.Email3" placeholder=" " id="e3" /><label for="e3">Emel 3</label></div>
    </div>

    @* ── NOTES ── *@
    <div class="form-section">
        <div class="form-section-title"><i class="bi bi-pencil"></i> Nota</div>
        <div class="text-field"><InputTextArea @bind-Value="c.Notes" placeholder=" " rows="3" id="nt" /><label for="nt">Nota tambahan</label></div>
    </div>

    <div style="display:flex;justify-content:flex-end;gap:8px;padding:16px">
        <a href="/" class="outlined-btn">Batal</a>
        <button type="submit" class="filled-btn" disabled="@saving"><i class="bi bi-check-lg"></i> Simpan</button>
    </div>
</EditForm>

@if (!string.IsNullOrEmpty(error)) { <div style="background:var(--md-error-container);padding:12px 16px;border-radius:8px;color:var(--md-error);margin-top:16px;font-size:.875rem">@error</div> }

@* TOAST *@
@if (toast is not null)
{
    <div class="toast-container"><div class="toast @(toast.IsError?"toast-error":"toast-success")">
        <i class="bi @(toast.IsError?"bi-exclamation-triangle-fill":"bi-check-circle-fill")"></i>
        <span>@toast.Message</span>
        <button class="toast-close" @onclick="()=>toast=null"><i class="bi bi-x"></i></button>
    </div></div>
}

@code {
    ContactForm c = new(); bool saving; string? error; ToastInfo? toast; const string ApiUrl = "api/contacts";
    string pasteText = ""; bool aiBusy; string? aiMsg;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { var s = await Http.GetFromJsonAsync<AuthStatus>("api/auth/status"); if (s?.IsAuthenticated != true) { Nav.NavigateTo("/login"); return; } }
        catch { Nav.NavigateTo("/login"); return; }
    }
    void ShowToast(string msg, bool err) { toast = new ToastInfo { Message = msg, IsError = err }; StateHasChanged(); _ = DismissToast(); }
    async Task DismissToast() { await Task.Delay(3000); toast = null; StateHasChanged(); }

    async Task ParseText()
    {
        if (string.IsNullOrWhiteSpace(pasteText) || aiBusy) return;
        aiBusy = true; aiMsg = null; StateHasChanged();
        try
        {
            var resp = await Http.PostAsJsonAsync("api/ai/parse", new { text = pasteText });
            if (resp.IsSuccessStatusCode)
            {
                var r = await resp.Content.ReadFromJsonAsync<AiParsed>();
                if (r is not null)
                {
                    c.Name = r.Name ?? ""; c.Honorific = r.Honorific; c.Gender = r.Gender;
                    c.Jawatan = r.Jawatan; c.Kementerian = r.Kementerian; c.Department = r.Department;
                    c.Mobile1 = r.Mobile; c.Phone1 = r.Phone; c.Email1 = r.Email;
                    c.Building = r.Building; c.PAName = r.PAName; c.PAMobile = r.PAMobile; c.Notes = r.Notes;
                    aiMsg = $"✅ Diisi: {c.Name}";
                }
            }
            else aiMsg = "❌ Gagal parse";
        }
        catch { aiMsg = "❌ Ralat AI"; }
        finally { aiBusy = false; StateHasChanged(); }
    }
    class AiParsed { public string? Name { get; set; } public string? Honorific { get; set; } public string? Gender { get; set; } public string? Jawatan { get; set; } public string? Kementerian { get; set; } public string? Department { get; set; } public string? Mobile { get; set; } public string? Phone { get; set; } public string? Email { get; set; } public string? Building { get; set; } public string? PAName { get; set; } public string? PAMobile { get; set; } public string? Notes { get; set; } }

    async Task Save()
    {
        saving = true; error = null;
        try
        {
            var r = await Http.PostAsJsonAsync(ApiUrl, c);
            if (r.IsSuccessStatusCode) { ShowToast("✅ " + c.Name + " ditambah", false); await Task.Delay(800); Nav.NavigateTo("/", forceLoad: true); }
            else { error = $"Ralat: {r.StatusCode}"; ShowToast("❌ Gagal menambah", true); }
        }
        catch (Exception ex) { error = ex.Message; ShowToast("❌ " + ex.Message, true); }
        finally { saving = false; }
    }

    class ContactForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Nama diperlukan")] public string Name { get; set; } = "";
        public string? Gender { get; set; } public string? Honorific { get; set; }
        public string? Jawatan { get; set; } public string? Company { get; set; }
        public string? Kementerian { get; set; } public string? Department { get; set; } public string? Bahagian { get; set; }
        public string? Building { get; set; } public string? Floor { get; set; } public string? Room { get; set; }
        public string? PAName { get; set; } public string? PAMobile { get; set; } public string? PAEmail { get; set; }
        public string? Mobile1 { get; set; } public string? Mobile2 { get; set; } public string? Mobile3 { get; set; } public string? Mobile4 { get; set; }
        public string? Phone1 { get; set; } public string? Phone2 { get; set; } public string? Phone3 { get; set; } public string? Phone4 { get; set; }
        public string? Email1 { get; set; } public string? Email2 { get; set; } public string? Email3 { get; set; }
        public string? Notes { get; set; }
    }
}
